# ─── Railway Environment Variables ───────────────────────────────────────────
# Copy these to Railway → Service → Variables before deploying.
# Never commit real values to git.

# Email (Zoho SMTP) — required for contact form
ZOHO_EMAIL=caleb@lykodigital.com
ZOHO_PASSWORD=your_zoho_password

# Port — Railway sets this automatically, do NOT override it
# PORT=3000
